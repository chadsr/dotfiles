[core]
    pager = delta
    symlinks = true

[interactive]
    diffFilter = delta --color-only --features=interactive

[delta]
    navigate = true    # use n and N to move between diff sections
    features = decorations
    syntax-theme = Catppuccin-Mocha

[delta "interactive"]
    keep-plus-minus-markers = false

[delta "decorations"]
    commit-style = raw
    file-style = omit
    hunk-header-style = file line-number syntax

[user]
    name = Ross
    email = git@ross.ch
    signingKey = 98B1F6BDC25DDD2560398F212B7340DB13C85766

[commit]
    gpgsign = true

[color]
    ui = true

[diff]
    colorMoved = default
    mnemonicprefix = true

[merge]
    conflictstyle = diff3

[rebase]
    autoStash = true
    autoSquash = true

[pull]
    rebase = true

[push]
    default = simple

[rerere]
    enabled = true

[url "https://bitbucket.org/"]
    insteadOf = bb:

[url "https://github.com/"]
    insteadOf = gh:

[url "https://gist.github.com/"]
    insteadOf = gist:

[url "https://gitlab.com/"]
    insteadOf = gl:

[url "https://codeberg.com/"]
    insteadOf = cb:

[tag]
    forceSignAnnotated = true

[alias]
    amend = commit --amend -m
    br = branch
    brd = branch -d
    brD = branch -D
    cm = commit -m
    co = switch
    cob = switch -c
    coo = !git fetch && git switch
    cp = cherry-pick
    f = "!git ls-files | grep -i"
    fea = fetch --all
    fixup = "!f() { t=${1:-HEAD}; b=$(git rev-parse $t^); git commit --fixup=$t && GIT_SEQUENCE_EDITOR=: git rebase -i --autosquash $b; }; f" # fixup <hash>: fold staged changes into <hash> (default: last commit), autosquash non-interactively
    fuckit = reset --hard origin/HEAD
    gr = grep -Ii
    la = "!git config -l | grep alias | cut -c 7-"
    ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
    ls = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate
    p = push
    pf = push --force-with-lease origin
    pl = pull
    po = push origin
    pu = !git push origin $(git branch --show-current)
    rb = !git fetch origin && git rebase --rebase-merges=no-rebase-cousins origin/HEAD
    rba = rebase --abort
    rbc = rebase --continue
    rbi = "!f() { git rebase -i HEAD~${1:-2}; }; f"
    rs = restore
    sh = stash
    st = status
    stp = stash pop
    undocommit = reset --soft HEAD^

[credential]
    helper = cache timeout=14400

[init]
    defaultBranch = main

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

# force --ff-only on known default/protected branches
[branch "master"]
    rebase = false
    mergeoptions = --ff-only

[branch "main"]
    rebase = false
    mergeoptions = --ff-only

[branch "develop"]
    rebase = false
    mergeoptions = --ff-only
