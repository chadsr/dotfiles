{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "lsp": {
    "basedpyright": {
      "command": [
        "basedpyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py"
      ]
    }
  },
  "mcp": {
    "brave-search": {
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "BRAVE_API_KEY",
        "docker.io/mcp/brave-search:latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "chrome-devtools-mcp": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath=/usr/bin/chromium",
        "--isolated=true",
        "--no-usage-statistics"
      ],
      "enabled": true,
      "type": "local"
    },
    "debugmcp": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:3001/mcp"
    },
    "gitmcp": {
      "enabled": true,
      "type": "remote",
      "url": "https://gitmcp.io/docs"
    }
  },
  "model": "zai-coding-plan/glm-5.1",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "tools": {
    "write": true
  }
}
