{
  "auths": {},
  "credsStore": "secretservice",
  "currentContext": "default",
  "features": {
    "hooks": "true",
    "profiles": "enabled"
  },
  "plugins": {
    "-x-cli-hints": {
      "enabled": "true"
    },
    "compose": {
      "hooks": "logs,compose logs,compose attach,compose up"
    },
    "debug": {
      "hooks": "exec"
    },
    "scout": {
      "hooks": "pull,buildx build"
    }
  }
}
