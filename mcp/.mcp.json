{
  "mcpServers": {
    "MCP_DOCKER": {
      "args": [
        "mcp",
        "gateway",
        "run",
        "--profile",
        "dev-tools"
      ],
      "command": "docker",
      "disable": false
    },
    "chrome-devtools-mcp": {
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath=/usr/bin/chromium",
        "--isolated=true",
        "--no-usage-statistics"
      ],
      "command": "npx",
      "disable": false
    }
  }
}
